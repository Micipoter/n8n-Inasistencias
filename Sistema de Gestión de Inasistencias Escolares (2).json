        "jsCode": "// Decisión automática: Aprobación\nconst data = $input.first().json;\nconst esValida = data.resultado_ia === 'Válida';\n\nreturn [{\n  json: {\n    ...data,\n    decision: esValida ? 'Aprobado' : 'Rechazado',\n    estado: 'Completado',\n    fecha_decision: new Date().toISOString(),\n    observaciones: `${data.observaciones_ia} | Decisión automática por alta confianza (${(data.nivel_confianza * 100).toFixed(1)}%).`\n  }\n}];"

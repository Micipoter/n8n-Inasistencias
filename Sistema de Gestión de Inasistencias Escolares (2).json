        "jsCode": "const data = $json.body || $json;\n\nconst nombre = data.nombre_estudiante || '';\nconst identificacion = data.id_estudiante || '';\nconst correo = data.correo || '';\n\nif (!nombre || !identificacion || !correo) {\n  throw new Error(\n    `Faltan campos obligatorios. Recibido: ${JSON.stringify(data)}`\n  );\n}\n\nreturn [\n  {\n    json: {\n      id_solicitud: 'SOL-' + Date.now(),\n      fecha_recepcion: new Date().toISOString(),\n      nombre_estudiante: nombre,\n      id_estudiante: identificacion,\n      correo: correo,\n      motivo_inasistencia: data.motivo_inasistencia || '',\n      tipo_justificacion: data.tipo_justificacion || '',\n      estado: 'Pendiente',\n      resultado_ia: '',\n      nivel_confianza: '',\n      texto_extraido: '',\n      decision: 'Pendiente',\n      fecha_decision: '',\n      observaciones: 'Solicitud recibida correctamente',\n      ultima_actualizacion: new Date().toISOString(),\n      inicio_procesamiento: Date.now(),\n      archivo_adjunto: data.archivo_adjunto ? 'ARCHIVO_PRESENTE' : ''\n    }\n  }\n];"
      },

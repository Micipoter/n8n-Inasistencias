    {
      "parameters": {
        "jsCode": "const solicitud = $input.first().json;\n\nconst textoSimulado = solicitud.archivo_adjunto ? \n  `[DOCUMENTO ANALIZADO] Tipo: ${solicitud.tipo_justificacion}. Contenido relacionado con: ${solicitud.motivo_inasistencia}.` : \n  'No se proporcionó documento adjunto';\n\nconst motivoLower = (solicitud.motivo_inasistencia || '').toLowerCase();\nconst tipoLower = (solicitud.tipo_justificacion || '').toLowerCase();\n\nlet resultado = 'Dudosa';\nlet confianza = 0.5;\nlet observaciones = '';\n\nconst palabrasValidas = ['enfermedad', 'médico', 'hospital', 'emergencia', 'fallecimiento', 'accidente', 'covid', 'quirúrgico', 'gripe', 'alergia', 'fiebre'];\nconst palabrasInvalidas = ['vacaciones', 'viaje', 'fiesta', 'descanso', 'personal', 'sin motivo'];\n\nconst tieneValidas = palabrasValidas.some(p => motivoLower.includes(p) || tipoLower.includes(p));\nconst tieneInvalidas = palabrasInvalidas.some(p => motivoLower.includes(p) || tipoLower.includes(p));\n\nif (tieneValidas && !tieneInvalidas) {\n  resultado = 'Válida';\n  confianza = 0.92;\n  observaciones = 'Motivo médico detectado. Alta confianza.';\n} else if (tieneInvalidas) {\n  resultado = 'Inválida';\n  confianza = 0.88;\n  observaciones = 'Motivo no justificable detectado.';\n} else {\n  resultado = 'Dudosa';\n  confianza = 0.55;\n  observaciones = 'No se detectaron indicadores claros. Requiere revisión manual.';\n}\n\nreturn [{\n  json: {\n    ...solicitud,\n    texto_extraido: textoSimulado,\n    resultado_ia: resultado,\n    nivel_confianza: confianza,\n    observaciones_ia: observaciones,\n    fecha_analisis: new Date().toISOString()\n  }\n}];"
      },
      "id": "568c65e6-a1ad-452c-9f51-6feb8826af32",
      "name": "Análisis IA (OCR + Clasificación)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -672,

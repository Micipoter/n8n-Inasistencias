      "parameters": {
        "jsCode": "// Cuando no hay archivo, marcar para revisión manual\nconst solicitud = {\n  ...$input.first().json,\n  nombre_estudiante: $('Validar y Estructurar Datos').item.json.nombre_estudiante || $input.first().json.nombre_estudiante,\n  id_estudiante: $('Validar y Estructurar Datos').item.json.id_estudiante || $input.first().json.id_estudiante,\n  correo: $('Validar y Estructurar Datos').item.json.correo || $input.first().json.correo\n};\n\nreturn [{\n  json: {\n    ...solicitud,\n    texto_extraido: 'No se adjuntó documento de soporte',\n    resultado_ia: 'Dudosa',\n    nivel_confianza: 0.3,\n    observaciones_ia: 'Solicitud sin archivo adjunto. Se requiere documento de soporte para validación.',\n    fecha_analisis: new Date().toISOString(),\n    decision: 'En Revisión'\n  }\n}];"
      },
